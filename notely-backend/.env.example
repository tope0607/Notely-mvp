PORT=3000
LISTEN_NOTES_API_KEY=your_api_key_here
DEEPGRAM_API_KEY=your_api_key_here

# Register an app at https://developer.spotify.com/dashboard
# Redirect URI must exactly match what you register there.
# Spotify requires https:// or a loopback IP literal (127.0.0.1) -- "localhost" is rejected as insecure.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

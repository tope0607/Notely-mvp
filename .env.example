# Notely environment variables — copy to `.env` and fill in.
# The real `.env` is gitignored; never commit secrets. This example is committed.
#
# Expo exposes only vars prefixed with EXPO_PUBLIC_ to the app bundle. The
# Spotify *client id* and *redirect uri* are safe to ship in a PKCE flow (no
# client secret is used on-device).

# Spotify OAuth (PKCE) — Track 2 / TOP-15.
# Create an app at https://developer.spotify.com/dashboard to get the client id.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id
# Must match a Redirect URI registered on the Spotify app. For a dev build this
# is typically your app scheme, e.g. notelymvp://redirect
EXPO_PUBLIC_SPOTIFY_REDIRECT_URI=notelymvp://redirect
